# MiMo Token Plan API Key
# 获取: https://xiaoai.mi.com/open-platform
MIMO_API_KEY=tp-xxxxxxxxxxxxxxxx

# MiMo API Base URL (Token Plan)
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 火山引擎方舟 API Key (仅四模型管线需要)
# 获取: https://console.volcengine.com/ark
ARK_API_KEY=ark-xxxxxxxxxxxxxxxx

# 火山引擎方舟 Base URL
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Seedance 模型
SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215

# TTS 脚本路径
# TTS_SCRIPTS=~/MiMo-Skills/skills/mimo-v2-5-tts/scripts

# 输出目录
# OUTPUT_DIR=/tmp/mimo-video-pipeline
